{
  "mcpServers": {
    "mcp-kali-server": {
      "command": "python3",
        "args": [
          "/absolute/path/to/client.py",
          "--server",
          "https://LINUX_IP:5000/",
          "--api-key",
          "YOUR_API_KEY_HERE",
          "--skip-verify"
        ],
        "description": "MCP Kali Server",
        "timeout": 300,
        "alwaysAllow": []
    }
  }
}
